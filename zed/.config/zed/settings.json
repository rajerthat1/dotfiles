{
  "cli_default_open_behavior": "existing_window",
  "terminal": {
    "font_size": 20.0,
    "font_family": "Agave"
  },
  "project_panel": {
    "dock": "right"
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "ui_font_size": 18.0,
  "icon_theme": "Zed (Default)",
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
    "gemini": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
  },
  "session": {
    "restore_unsaved_buffers": false,
    "trust_all_worktrees": true,
  },
  "show_edit_predictions": false,
  "disable_ai": false,
  "ui_font_family": ".ZedSans",
  "which_key": {
    "enabled": true,
  },
  "inlay_hints": {
    "show_value_hints": true,
  },
  "toolbar": {
    "code_actions": false,
    "quick_actions": true,
  },
  "inline_code_actions": true,
  "gutter": {
    "folds": true,
  },
  "buffer_font_size": 16.0,
  "colorize_brackets": false,
  "show_whitespaces": "none",
  "use_system_path_prompts": true,
  "buffer_line_height": "standard",
  "buffer_font_family": "Maple Mono",
  "buffer_font_features": {
    "calt": false,
  },
  "cursor_blink": false,
  "theme": {
    "mode": "dark",
    "light": "Gruvbox Light Hard",
    "dark": "Jellybeans",
  },
  "agent": {
    "dock": "left",
    "enable_feedback": false,
    "default_profile": "write",
    "favorite_models": [],
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "deepseek",
      "model": "deepseek-v4-flash",
    },
    "model_parameters": [],
  },
  "scrollbar": {
    "show": "always",
  },
  "relative_line_numbers": "enabled",
  "vim_mode": true,
  "minimap": {
    "show": "never",
  },
}
