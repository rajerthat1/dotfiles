// This configuration is merged with the default vicinae configuration file, which you can obtain by running the `vicinae config default` command.
// Every item defined in this file takes precedence over the values defined in the default config or any other imported file.
//
// You can make manual edits to this file, however you should keep in mind that this file may be written to by vicinae when a configuration change is made through the GUI.
// When that happens, any custom comments or formatting will be lost.
//
// If you want to maintain a configuration file with your own comments and formatting, you should create a separate file and add it to the 'imports' array.
//
// Learn more about configuration at https://docs.vicinae.com/config

{
   "$schema": "https://vicinae.com/schemas/config.json",
   "close_on_focus_loss": true,
   "font": {
      "normal": {
         "family": "Atkinson Hyperlegible Next Medium",
         "size": 12
      }
   },
   "theme": {
      "dark": {
         "name": "zenwritten-dark"
      }
   },
   "telemetry": {
      "system_info": false
   },
   "launcher_window": {
      "opacity": 1,
      "client_side_decorations": {
         "enabled": true
      }
   },
   "providers": {
      "applications": {
         "preferences": {
            "defaultAction": "focus",
            "paths": [
               "/home/raj/.local/share/applications",
               "/usr/share/ubuntu/applications",
               "/usr/share/gnome/applications",
               "/home/raj/.local/share/flatpak/exports/share/applications",
               "/var/lib/flatpak/exports/share/applications",
               "/usr/local/share/applications",
               "/usr/share/applications",
               "/var/lib/snapd/desktop/applications"
            ]
         }
      },
      "browser-extension": {
         "enabled": false,
         "entrypoints": {
            "shortcut-active-tab": {
               "enabled": false
            }
         }
      },
      "clipboard": {
         "enabled": false,
         "preferences": {
            "encryption": false,
            "eraseOnStartup": false,
            "ignorePasswords": true,
            "monitoring": false
         }
      },
      "core": {
         "enabled": false
      },
      "developer": {
         "enabled": false
      },
      "files": {
         "enabled": false,
         "preferences": {
            "autoIndexing": true,
            "excludedPaths": "",
            "paths": "/home/raj",
            "watcherPaths": ""
         }
      },
      "font": {
         "enabled": false
      },
      "manage-shortcuts": {
         "enabled": false
      },
      "raycast-compat": {
         "enabled": false
      },
      "scripts": {
         "enabled": false
      },
      "shortcuts": {
         "enabled": false
      },
      "system": {
         "enabled": false
      },
      "theme": {
         "enabled": true,
         "entrypoints": {
            "set": {
               "enabled": true
            }
         }
      },
      "wm": {
         "enabled": false
      }
   }
}